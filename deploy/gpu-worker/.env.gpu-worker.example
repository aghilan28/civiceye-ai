CIVICEYE_BACKEND_URL=https://api.civiceye.example.com
DATABASE_URL=postgresql://civiceye:change-me@postgres.example.com:5432/civiceye
REDIS_URL=redis://redis.example.com:6379/0
CIVICEYE_WORKER_SHARED_SECRET=replace-with-a-high-entropy-worker-secret-at-least-24-chars
CIVICEYE_WORKER_ID=gpu-worker-remote-0
CIVICEYE_QUEUE_NAMES=gpu.emergency,gpu.high,gpu.standard
CIVICEYE_MODEL_DIR=../../ai/checkpoints
CIVICEYE_MODEL_VERSION=pothole-yolov8-v0.2.0
CIVICEYE_WORKER_RUNTIME_VERSION=2.0.0
CIVICEYE_WORKER_CONCURRENCY=1
CIVICEYE_VALIDATE_MODEL_PRELOAD=1
