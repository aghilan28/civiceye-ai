{
  "title": "CivicEye AI Inference",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Inference latency",
      "targets": [
        { "expr": "histogram_quantile(0.95, sum(rate(civiceye_inference_latency_ms_bucket[5m])) by (le, model_type))" }
      ]
    },
    {
      "type": "timeseries",
      "title": "Inference detections",
      "targets": [
        { "expr": "sum(rate(civiceye_inference_detections_total[5m])) by (model_type)" }
      ]
    }
  ]
}
